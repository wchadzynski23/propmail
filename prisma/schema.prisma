generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  name         String?
  createdAt    DateTime      @default(now())
  settings     UserSettings?
  templates    Template[]
  sends        EmailSend[]
  unsubscribes Unsubscribe[]
  contacts     Contact[]
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  phone     String?
  company   String?
  notes     String?
  tags      String?  // comma-separated: "buyer,investor"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, email])
}

model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resendApiKey      String?
  senderEmail       String?
  senderName        String?
  // Agent footer / signature
  footerAgentName   String?
  footerTitle       String?
  footerPhone       String?
  footerAddress     String?  // Physical address — required for CAN-SPAM
  footerWebsite     String?
  footerCustomText  String?  // Free-form closing note
  // SMTP / sending provider
  smtpProvider      String?  // "resend" | "gmail" | "outlook" | "yahoo" | "custom"
  smtpHost          String?
  smtpPort          Int?
  smtpSecure        Boolean? // true = TLS on connect (port 465), false = STARTTLS (587)
  smtpUser          String?
  smtpPassword      String?
}

model Template {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  blocks    String      // JSON string
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  sends     EmailSend[]
}

model EmailSend {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  recipients String   // JSON string: [{email, name}]
  status     String   @default("sent")
  sentAt     DateTime @default(now())
}

// One row per (agent, recipient email).
// token  — included in every email's unsubscribe URL.
// unsubscribedAt — null means still subscribed; set = opted out.
model Unsubscribe {
  id               String    @id @default(cuid())
  token            String    @unique @default(cuid())
  agentUserId      String
  agentUser        User      @relation(fields: [agentUserId], references: [id], onDelete: Cascade)
  email            String
  unsubscribedAt   DateTime?
  createdAt        DateTime  @default(now())

  @@unique([agentUserId, email])
}
